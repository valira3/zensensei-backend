# ZenSensei Backend Configuration
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production
API_VERSION=v1

# Service Ports
USER_SERVICE_PORT=8001
GRAPH_QUERY_SERVICE_PORT=8002
AI_REASONING_SERVICE_PORT=8003
INTEGRATION_SERVICE_PORT=8004
NOTIFICATION_SERVICE_PORT=8005
ANALYTICS_SERVICE_PORT=8006
API_GATEWAY_PORT=4000

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localdev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase / Identity Platform
FIREBASE_PROJECT_ID=zensensei-platform
FIREBASE_CREDENTIALS_PATH=./credentials/firebase-sa.json

# Google Cloud
GCP_PROJECT_ID=zensensei-platform
GCP_REGION=us-central1

# BigQuery
BIGQUERY_DATASET=analytics

# Pub/Sub Topics
PUBSUB_USER_EVENTS_TOPIC=user-events
PUBSUB_GRAPH_UPDATES_TOPIC=graph-updates
PUBSUB_AI_JOBS_TOPIC=ai-jobs

# AI/ML
GEMINI_MODEL=gemini-1.5-pro
VERTEX_AI_LOCATION=us-central1

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@zensensei.net

# Integration OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PLAID_CLIENT_ID=
PLAID_SECRET=

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
