// =========================
// PASSWORD STRENGTH
// =========================
function getPwStrength(pw) {
  const rules = {
    length:  pw.length >= 8,
    upper:   /[A-Z]/.test(pw),
    lower:   /[a-z]/.test(pw),
    number:  /[0-9]/.test(pw),
    special: /[^A-Za-z0-9]/.test(pw)
  };
  const score = Object.values(rules).filter(Boolean).length;
  return { rules, score };
}

function updatePwStrength() {
  const pw = document.getElementById('regPassword').value;
  const { rules, score } = getPwStrength(pw);

  // Requirements
  setReq('req-length',  rules.length);
  setReq('req-upper',   rules.upper);
  setReq('req-lower',   rules.lower);
  setReq('req-number',  rules.number);
  setReq('req-special', rules.special);

  // Strength bar
  const fill = document.getElementById('pwStrengthFill');
  const label = document.getElementById('pwStrengthLabel');
  if (!pw) {
    fill.style.width = '0';
    fill.style.background = '';
    label.textContent = '';
    label.style.color = '';
    return;
  }
  if (score <= 2) {
    fill.style.width = '33%';
    fill.style.background = 'var(--color-error)';
    label.textContent = 'Weak';
    label.style.color = 'var(--color-error)';
  } else if (score <= 3) {
    fill.style.width = '66%';
    fill.style.background = 'var(--color-warning)';
    label.textContent = 'Medium';
    label.style.color = 'var(--color-warning)';
  } else {
    fill.style.width = '100%';
    fill.style.background = 'var(--color-success)';
    label.textContent = 'Strong';
    label.style.color = 'var(--color-success)';
  }
}

function setReq(id, met) {
  const el = document.getElementById(id);
  if (!el) return;
  el.classList.toggle('met', met);
  const icon = el.querySelector('.pw-req-icon');
  if (met) {
    icon.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>';
  } else {
    icon.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
  }
}

// =========================
// CONFIRM PASSWORD VALIDATION
// =========================
function validateConfirmPw() {
  const pw = document.getElementById('regPassword').value;
  const confirm = document.getElementById('regConfirm').value;
  const el = document.getElementById('regConfirm');
  const msg = document.getElementById('regConfirmMsg');
  if (!confirm) { el.classList.remove('error'); msg.textContent = ''; msg.className = 'auth-field-msg'; return; }
  if (pw === confirm) {
    el.classList.remove('error');
    msg.textContent = 'Passwords match';
    msg.className = 'auth-field-msg ok';
  } else {
    el.classList.add('error');
    msg.textContent = 'Passwords do not match';
    msg.className = 'auth-field-msg error';
  }
}

// =========================
// FORGOT PASSWORD HANDLER
// =========================
function handleForgotPassword() {
  const emailEl = document.getElementById('forgotEmail');
  const msg = document.getElementById('forgotEmailMsg');
  const btn = document.getElementById('forgotBtn');
  const email = emailEl.value.trim();

  if (!isValidEmail(email)) {
    emailEl.classList.add('error');
    msg.textContent = 'Please enter a valid email address.';
    msg.className = 'auth-field-msg error';
    return;
  }
  emailEl.classList.remove('error');
  msg.textContent = '';
  msg.className = 'auth-field-msg';

  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div>';

  setTimeout(() => {
    btn.disabled = false;
    btn.textContent = 'Send Reset Link';
    // Show success state
    document.getElementById('forgotFormState').style.display = 'none';
    const successDesc = document.getElementById('forgotSuccessDesc');
    successDesc.textContent = 'We sent a password reset link to ' + email + '.';
    const successBox = document.getElementById('forgotSuccessState');
    successBox.classList.add('visible');
    startResendTimer('forgotResendWrap', () => {
      // resend stub
    });
  }, 1000);
}

// =========================
// RESEND TIMER
// =========================
function startResendTimer(wrapperId, onResend) {
  const wrap = document.getElementById(wrapperId);
  if (!wrap) return;
  let seconds = 59;

  function tick() {
    if (seconds > 0) {
      wrap.innerHTML = '<span>Resend link in ' + seconds + 's</span>';
      seconds--;
      setTimeout(tick, 1000);
    } else {
      wrap.innerHTML = '<span class="resend-active" onclick="this.parentElement._onResend && this.parentElement._onResend()">Resend link</span>';
    }
  }
  wrap._onResend = onResend;
  tick();
}

