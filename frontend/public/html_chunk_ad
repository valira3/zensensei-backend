// DARK MODE UPDATE — fix aria-pressed
// =========================
// Patch toggleDarkMode to also update aria-pressed
const _patchDarkModeAria = () => {
  const toggle = document.getElementById('darkModeToggle');
  if (toggle) toggle.setAttribute('aria-pressed', toggle.classList.contains('on'));
};
// Wrap after initial declaration via monkey-patching on DOMContentLoaded
document.addEventListener('DOMContentLoaded', () => {
  const dmToggle = document.getElementById('darkModeToggle');
  if (dmToggle) {
    dmToggle.addEventListener('click', () => {
      requestAnimationFrame(() => {
        dmToggle.setAttribute('aria-pressed', dmToggle.classList.contains('on'));
      });
    });
  }
});

