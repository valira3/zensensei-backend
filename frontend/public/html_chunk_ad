// =========================
// LOGOUT MODAL
// =========================
function openLogoutModal() {
  document.getElementById('logoutModal').classList.add('open');
}
function closeLogoutModal() {
  document.getElementById('logoutModal').classList.remove('open');
}
function confirmLogout() {
  closeLogoutModal();
  Auth.logout();
  // Reset forgot-password form state in case user returns
  const formState = document.getElementById('forgotFormState');
  if (formState) formState.style.display = '';
  const successBox = document.getElementById('forgotSuccessState');
  if (successBox) successBox.classList.remove('visible');
  showAuthScreen('screen-login');
}

// Close logout modal on backdrop click
document.addEventListener('DOMContentLoaded', () => {
  const lm = document.getElementById('logoutModal');
  if (lm) lm.addEventListener('click', e => { if (e.target === lm) closeLogoutModal(); });
  const dm = document.getElementById('deleteAccountModal');
  if (dm) dm.addEventListener('click', e => { if (e.target === dm) closeDeleteModal(); });
});

// =========================
// TOAST SYSTEM
// =========================
function showToast(message, type='info', duration=3000) {
  const container = document.getElementById('toastContainer');
  if (!container) return;
  const toast = document.createElement('div');
  toast.className = 'toast toast-' + type;
  const icons = { success: '✓', error: '✕', info: 'ℹ' };
  toast.innerHTML = '<span style="font-size:16px;">' + (icons[type] || icons.info) + '</span><span>' + message + '</span>';
  container.appendChild(toast);
  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transition = 'opacity 300ms';
    setTimeout(() => toast.remove(), 350);
  }, duration);
}

// =========================
// ACCORDION (FAQ)
// =========================
function toggleAccordion(id) {
  const item = document.getElementById(id);
  if (!item) return;
  const isOpen = item.classList.contains('open');
  // Close all in the same card
  const parent = item.closest('.card');
  if (parent) {
    parent.querySelectorAll('.accordion-item').forEach(el => {
      el.classList.remove('open');
      const btn = el.querySelector('.accordion-header');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
  }
  if (!isOpen) {
    item.classList.add('open');
    const btn = item.querySelector('.accordion-header');
    if (btn) btn.setAttribute('aria-expanded', 'true');
  }
}

// =========================
// DELETE ACCOUNT MODAL
// =========================
function openDeleteModal() {
  const overlay = document.getElementById('deleteAccountModal');
  if (overlay) {
    overlay.classList.add('open');
    document.getElementById('deleteConfirmInput').value = '';
  }
}
function closeDeleteModal() {
  const overlay = document.getElementById('deleteAccountModal');
  if (overlay) overlay.classList.remove('open');
}
function submitDeleteAccount() {
  const val = document.getElementById('deleteConfirmInput').value.trim();
  if (val !== 'DELETE') {
    document.getElementById('deleteConfirmInput').focus();
    document.getElementById('deleteConfirmInput').style.borderColor = 'var(--color-error)';
    showToast('Please type DELETE to confirm.', 'error');
    return;
  }
  closeDeleteModal();
  Auth.logout();
  showAuthScreen('screen-login');
  showToast('Your account has been deleted.', 'success');
}

// =========================
// MASTER PUSH TOGGLE
// =========================
function toggleMasterPush(btn) {
  btn.classList.toggle('on');
  const isOn = btn.classList.contains('on');
  btn.setAttribute('aria-pressed', isOn);
  // Disable/enable category toggles
  const screen = document.getElementById('screen-notifications');
  if (!screen) return;
  const categoryToggles = screen.querySelectorAll('.toggle-switch:not(#masterPushToggle)');
  categoryToggles.forEach(t => {
    t.disabled = !isOn;
    t.style.opacity = isOn ? '' : '0.4';
  });
}

// =========================
// BUG REPORT
// =========================
function submitBugReport() {
  const desc = document.getElementById('bugDesc').value.trim();
  if (!desc) {
    showToast('Please describe the issue before sending.', 'error');
    return;
  }
  document.getElementById('bugDesc').value = '';
  showToast('Bug report sent. Thank you!', 'success');
}

// =========================
// PROFILE SAVE
// =========================
function saveProfile() {
  const name = document.getElementById('editName').value.trim();
  const bio  = document.getElementById('editBio').value.trim();
  if (!name) { showToast('Name cannot be empty.', 'error'); return; }
  // Update profile display
  const profileName = document.querySelector('#screen-profile .profile-name');
  const profileBio  = document.querySelector('#screen-profile .profile-bio');
  if (profileName) profileName.textContent = name;
  if (profileBio)  profileBio.textContent = bio;
  showToast('Profile updated successfully.', 'success');
  goBack();
}

