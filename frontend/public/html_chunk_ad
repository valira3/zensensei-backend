<script>
// =========================
// APP STATE
// =========================
let currentTheme = 'light';
let currentScreen = 'screen-home';
let screenHistory = ['screen-home'];

// =========================
// NAVIGATION
// =========================
function switchTab(screenId) {
  currentScreen = screenId;
  screenHistory = [screenId];
  showScreen(screenId);
  updateNav(screenId);
  scrollToTop();
}

function navigateTo(screenId) {
  screenHistory.push(screenId);
  currentScreen = screenId;
  showScreen(screenId);
  updateNav(null);
  scrollToTop();
}

function goBack() {
  screenHistory.pop();
  const prev = screenHistory[screenHistory.length - 1] || 'screen-home';
  currentScreen = prev;
  showScreen(prev, true);
  updateNav(prev);
  scrollToTop();
}

function showScreen(id, reverse) {
  document.querySelectorAll('.screen').forEach(s => {
    s.classList.remove('active');
    s.style.animation = '';
  });
  const el = document.getElementById(id);
  if (el) {
    el.classList.add('active');
    el.style.animation = reverse ? 'fadeInReverse 0.3s var(--ease)' : 'fadeIn 0.3s var(--ease)';
    // Animate progress bars on this screen
    requestAnimationFrame(() => animateProgressBars(el));
  }
}

function updateNav(activeTab) {
  document.querySelectorAll('.nav-item').forEach(n => {
    n.classList.toggle('active', n.dataset.tab === activeTab);
  });
}

function scrollToTop() {
  document.getElementById('appContent').scrollTop = 0;
}

// =========================
// MODAL
// =========================
function openModal() {
  document.getElementById('logModal').classList.add('open');
}
function closeModal() {
  document.getElementById('logModal').classList.remove('open');
}
document.getElementById('logModal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// =========================
// DARK MODE
// =========================
function toggleDarkMode() {
  currentTheme = currentTheme === 'light' ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', currentTheme);
  const toggle = document.getElementById('darkModeToggle');
  if (toggle) toggle.classList.toggle('on', currentTheme === 'dark');
}

// =========================
// PROGRESS BAR ANIMATION
// =========================
function animateProgressBars(container) {
  const root = container || document;
  root.querySelectorAll('.progress-fill[data-width]').forEach(bar => {
    bar.style.width = '0%';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        bar.style.width = bar.dataset.width;
      });
    });
  });

  // Sleep bars
  root.querySelectorAll('.sleep-bar[data-height]').forEach(bar => {
    bar.style.height = '0';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        bar.style.height = bar.dataset.height;
      });
    });
  });

  // Spending bars
  root.querySelectorAll('.spending-fill[data-width]').forEach(bar => {
    bar.style.width = '0%';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        bar.style.width = bar.dataset.width;
      });
    });
  });

  // Budget ring
  root.querySelectorAll('.fill-ring[data-pct]').forEach(ring => {
    const circumference = 2 * Math.PI * 54;
    const pct = parseFloat(ring.dataset.pct) / 100;
    const offset = circumference * (1 - pct);
    ring.style.strokeDashoffset = circumference;
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        ring.style.strokeDashoffset = offset;
      });
    });
  });
}

// =========================
// HEATMAP GENERATION
// =========================
function generateHeatmap() {
  const container = document.getElementById('heatmap');
  if (!container) return;

  const days = ['', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
  const hours = ['8am', '10am', '12pm', '2pm', '4pm', '6pm', '8pm'];

  // Header row
  days.forEach(d => {
    const el = document.createElement('div');
    el.className = 'heatmap-label';
    el.textContent = d;
    el.style.justifyContent = d === '' ? 'flex-end' : 'center';
    el.style.fontSize = '9px';
    container.appendChild(el);
  });

  // Data (higher = more productive)
  const data = [
    [3,5,7,8,6,4,2],
    [4,6,8,9,7,3,2],
    [5,4,6,7,8,5,3],
    [6,7,5,6,7,6,4],
    [8,9,7,5,4,7,5],
    [7,8,6,4,3,8,6],
    [4,5,3,2,2,5,4],
  ];

  const getColor = (v, theme) => {
    if (v <= 2) return theme === 'dark' ? 'rgba(59,130,246,0.05)' : 'rgba(59,130,246,0.05)';
    if (v <= 4) return theme === 'dark' ? 'rgba(59,130,246,0.15)' : 'rgba(59,130,246,0.12)';
    if (v <= 6) return theme === 'dark' ? 'rgba(59,130,246,0.3)' : 'rgba(59,130,246,0.25)';
    if (v <= 8) return theme === 'dark' ? 'rgba(59,130,246,0.5)' : 'rgba(59,130,246,0.45)';
    return theme === 'dark' ? 'rgba(59,130,246,0.7)' : 'rgba(59,130,246,0.65)';
  };

  hours.forEach((h, i) => {
    const label = document.createElement('div');
    label.className = 'heatmap-label';
    label.textContent = h;
    container.appendChild(label);
    data[i].forEach(v => {
      const cell = document.createElement('div');
      cell.className = 'heatmap-cell';
      cell.style.background = getColor(v, currentTheme);
      cell.title = `${h}, ${days[data[i].indexOf(v) + 1]}: ${v}/10`;
      container.appendChild(cell);
    });
  });
}

// =========================
// INIT
// =========================
document.addEventListener('DOMContentLoaded', () => {
  // Init Lucide icons
  if (typeof lucide !== 'undefined') {
    lucide.createIcons();
  }

  // Generate heatmap
  generateHeatmap();

  // Auth-gated startup: show login first, unless already authenticated
  if (Auth.init()) {
    // Already authenticated — go straight to app
    showAppScreen('screen-home');
    requestAnimationFrame(() => {
      animateProgressBars(document.getElementById('screen-home'));
    });
  } else {
    // Not authenticated — show login screen (hide chrome)
    showAuthScreen('screen-login');
  }
});

// =========================
// AUTH STATE MANAGER
// =========================
const Auth = {
  token: null,
  user: null,
  isAuthenticated() { return !!this.token; },
  login(token, user) {
    this.token = token;
    this.user = user;
    sessionStorage.setItem('zensensei_token', token);
    if (user) sessionStorage.setItem('zensensei_user', JSON.stringify(user));
  },
  logout() {
    this.token = null;
    this.user = null;
    sessionStorage.removeItem('zensensei_token');
    sessionStorage.removeItem('zensensei_user');
  },
  init() {
    this.token = sessionStorage.getItem('zensensei_token');
    const stored = sessionStorage.getItem('zensensei_user');
    if (stored) { try { this.user = JSON.parse(stored); } catch(e) {} }
    return this.isAuthenticated();
  }
};

// =========================
// AUTH SCREEN NAVIGATION
// =========================
const AUTH_SCREENS = ['screen-login', 'screen-register', 'screen-forgot', 'screen-verify'];

function showAuthScreen(id) {
  // Hide all screens
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  // Show/hide shell chrome
  const inner = document.querySelector('.phone-inner');
  if (AUTH_SCREENS.includes(id)) {
    inner.classList.add('app-shell-auth');
  } else {
    inner.classList.remove('app-shell-auth');
  }
  const el = document.getElementById(id);
  if (el) {
    el.classList.add('active');
    el.style.animation = 'fadeIn 0.3s var(--ease)';
  }
}

function showAppScreen(screenId) {
  screenId = screenId || 'screen-home';
  const inner = document.querySelector('.phone-inner');
  inner.classList.remove('app-shell-auth');
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById(screenId);
  if (el) {
    el.classList.add('active');
    el.style.animation = 'fadeIn 0.3s var(--ease)';
    requestAnimationFrame(() => animateProgressBars(el));
  }
  updateNav(screenId);
  screenHistory = [screenId];
  currentScreen = screenId;
  scrollToTop();
}

// =========================
// LOGIN HANDLER
// =========================
function handleLogin() {
  const emailEl = document.getElementById('loginEmail');
  const pwEl = document.getElementById('loginPassword');
  const btn = document.getElementById('loginBtn');
  const errMsg = document.getElementById('loginError');

  const email = emailEl.value.trim();
  const pw = pwEl.value;

  // Basic validation
  if (!email || !isValidEmail(email)) {
    showLoginError('Please enter a valid email address.');
    emailEl.classList.add('error');
    return;
  }
  if (!pw) {
    showLoginError('Please enter your password.');
    pwEl.classList.add('error');
    return;
  }

  emailEl.classList.remove('error');
  pwEl.classList.remove('error');
  errMsg.classList.remove('visible');

  // Show spinner / loading state
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div>';

  // Simulate API call
  setTimeout(() => {
    btn.disabled = false;
    btn.textContent = 'Log In';

    // For demo: any valid email/pw logs in
    const fakeToken = 'demo_token_' + Date.now();
    const user = { name: email.split('@')[0], email: email };
    Auth.login(fakeToken, user);
    showAppScreen('screen-home');

    // Re-init icons for newly visible screens
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }, 1000);
}

function showLoginError(msg) {
  const errMsg = document.getElementById('loginError');
  errMsg.textContent = msg;
  errMsg.classList.add('visible');
  const form = document.getElementById('screen-login').querySelector('.auth-body');
  form.classList.remove('shake');
  requestAnimationFrame(() => {
    requestAnimationFrame(() => form.classList.add('shake'));
  });
  // Remove shake after animation completes
  setTimeout(() => form.classList.remove('shake'), 500);
}

// =========================
// SOCIAL LOGIN (STUB)
// =========================
function handleSocialLogin(event, provider) {
  // Demo: simulate successful social login
  const btn = event.currentTarget;
  const origHTML = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner" style="border-top-color:var(--color-primary); border-color:var(--color-border);"></div><span>Connecting…</span>';

  setTimeout(() => {
    btn.disabled = false;
    btn.innerHTML = origHTML;
    const fakeToken = provider.toLowerCase() + '_token_' + Date.now();
    Auth.login(fakeToken, { name: 'Val', email: 'val@example.com', provider });
    showAppScreen('screen-home');
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }, 1000);
}

// =========================
// REGISTER HANDLER
// =========================
function handleRegister() {
  const name = document.getElementById('regName').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pw = document.getElementById('regPassword').value;
  const confirm = document.getElementById('regConfirm').value;
  const agree = document.getElementById('agreeTerms').checked;
  const btn = document.getElementById('registerBtn');

  if (!name) { alert('Please enter your full name.'); return; }
  if (!isValidEmail(email)) {
    document.getElementById('regEmail').classList.add('error');
    document.getElementById('regEmailMsg').textContent = 'Please enter a valid email.';
    document.getElementById('regEmailMsg').className = 'auth-field-msg error';
    return;
  }
  const strength = getPwStrength(pw);
  if (strength.score < 2) { alert('Please choose a stronger password.'); return; }
  if (pw !== confirm) {
    document.getElementById('regConfirm').classList.add('error');
    document.getElementById('regConfirmMsg').textContent = 'Passwords do not match.';
    document.getElementById('regConfirmMsg').className = 'auth-field-msg error';
    return;
  }
  if (!agree) { alert('Please agree to the Terms of Service and Privacy Policy.'); return; }

  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div>';

  setTimeout(() => {
    btn.disabled = false;
    btn.textContent = 'Create Account';
    // Show verification screen
    const verifyDesc = document.getElementById('verifyDesc');
    verifyDesc.textContent = 'We sent a verification link to ' + email + '.';
    showAuthScreen('screen-verify');
    startResendTimer('verifyResendWrap', () => {
      // resend action stub
    });
  }, 1000);
}

// =========================
// EMAIL VALIDATION
// =========================
function isValidEmail(email) {
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
}

function validateRegEmail() {
  const el = document.getElementById('regEmail');
  const msg = document.getElementById('regEmailMsg');
  const val = el.value.trim();
  if (!val) { el.classList.remove('error'); msg.textContent = ''; msg.className = 'auth-field-msg'; return; }
  if (isValidEmail(val)) {
    el.classList.remove('error');
    msg.textContent = '';
    msg.className = 'auth-field-msg';
  } else {
    el.classList.add('error');
    msg.textContent = 'Please enter a valid email address.';
    msg.className = 'auth-field-msg error';
  }
}

// =========================
// PASSWORD VISIBILITY TOGGLE
// =========================
